{
  "metadata": [
    {
      "src": [
        {
          "files": [ "Engine.csproj" ],
          "src": "."
        }
      ],
      "dest": "api",
      "allowCompilationErrors": true
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "toc.yml", "index.md", "Documentation.md" ]
      },
      {
        "files": [ "api/**.yml", "api/index.md" ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "IoT Swarm Mesh — Engine Docs",
      "_appName": "IoT Swarm Mesh",
      "_appFooter": "IoT Swarm Mesh Simulation Engine",
      "_enableSearch": true
    },
    "template": [ "default", "modern" ]
  }
}
