@using WebApp.Client.Services
@using Engine.Core
@using Engine.Routers

<div class="modal-backdrop" @onclick="OnBackdropClick">
    <div class="modal-box settings-modal" @onclick:stopPropagation>
        <h3>Simulation settings</h3>

        <div class="settings-stat">
            <span>Last tick work</span>
            <strong>@LastTickMs.ToString("F2") ms</strong>
        </div>

        <label>
            Routing strategy
            <select class="form-input" value="@_routerIndex" @onchange="OnRouterChanged">
                @for (int i = 0; i < SimulationConfig.AvailableRouters.Count; i++)
                {
                    <option value="@i">@SimulationConfig.AvailableRouters[i].Name</option>
                }
            </select>
        </label>

        <label>
            Topology builder
            <select class="form-input" value="@_builderIndex" @onchange="OnBuilderChanged">
                @for (int i = 0; i < SimulationConfig.AvailableNetworkBuilders.Count; i++)
                {
                    <option value="@i">@SimulationConfig.AvailableNetworkBuilders[i].Name</option>
                }
            </select>
        </label>

        <h3>Swarm parameter vector</h3>

        <div class="settings-vector-grid">
            <label>
                qForward
                <input class="form-input" type="number" min="20" max="1800"
                       @bind="Config.SwarmVector.QForward" />
            </label>

            <label>
                Root source charge
                <input class="form-input" type="number" min="250" max="3000"
                       @bind="Config.SwarmVector.RootSourceCharge" />
            </label>

            <label>
                Penalty lambda
                <input class="form-input" type="number" min="0" max="250" step="1"
                       @bind="Config.SwarmVector.PenaltyLambda" />
            </label>

            <label>
                Switch hysteresis
                <input class="form-input" type="number" min="0" max="260"
                       @bind="Config.SwarmVector.SwitchHysteresis" />
            </label>

            <label>
                Switch hysteresis ratio
                <input class="form-input" type="number" min="0" max="0.4" step="0.01"
                       @bind="Config.SwarmVector.SwitchHysteresisRatio" />
            </label>

            <label>
                Parent dead ticks
                <input class="form-input" type="number" min="1" max="10000"
                       @bind="Config.SwarmVector.ParentDeadTicks" />
            </label>

            <label>
                Charge drop per hop
                <input class="form-input" type="number" min="5" max="420"
                       @bind="Config.SwarmVector.ChargeDropPerHop" />
            </label>

            <label>
                Charge spread factor
                <input class="form-input" type="number" min="0.01" max="1" step="0.01"
                       @bind="Config.SwarmVector.ChargeSpreadFactor" />
            </label>

            <label>
                Decay interval ticks
                <input class="form-input" type="number" min="0" max="2000"
                       @bind="Config.SwarmVector.DecayIntervalSteps" />
            </label>

            <label>
                Decay percent
                <input class="form-input" type="number" min="0" max="0.8" step="0.01"
                       @bind="Config.SwarmVector.DecayPercent" />
            </label>

            <label>
                Link memory
                <input class="form-input" type="number" min="0.6" max="0.999" step="0.001"
                       @bind="Config.SwarmVector.LinkMemory" />
            </label>

            <label>
                Link learning rate
                <input class="form-input" type="number" min="0.01" max="2" step="0.01"
                       @bind="Config.SwarmVector.LinkLearningRate" />
            </label>

            <label>
                Link bonus max
                <input class="form-input" type="number" min="0" max="240"
                       @bind="Config.SwarmVector.LinkBonusMax" />
            </label>
        </div>

        <label>
            Visibility distance (units)
            <input class="form-input" type="number" min="50" max="1000"
                   @bind="Config.VisibilityDistance" />
        </label>

        <label>
            Default TTL
            <input class="form-input" type="number" min="1" max="64"
                   @bind="Config.DefaultTTL" />
        </label>

        <label>
            Ticks to travel
            <input class="form-input" type="number" min="1" max="20"
                   @bind="Config.TicksToTravel" />
        </label>

        <label>
            Max active packets <span class="settings-hint">(0 = auto: devices ? @SimulationEngine.AUTO_PACKET_LIMIT_PER_DEVICE, now @_autoLimit)</span>
            <input class="form-input" type="number" min="0"
                   @bind="Config.MaxActivePackets" />
        </label>

        <div class="modal-actions">
            <button class="btn btn-primary" @onclick="Apply">Apply</button>
            <button class="btn btn-ghost" @onclick="Close">Close</button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public SimulationConfig Config      { get; set; } = new();
    [Parameter, EditorRequired] public double           LastTickMs  { get; set; }
    [Parameter, EditorRequired] public int              DeviceCount { get; set; }
    [Parameter]                 public EventCallback    OnApply     { get; set; }
    [Parameter]                 public EventCallback    OnClose     { get; set; }

    // Index into SimulationConfig.AvailableRouters, kept in sync with Config.SelectedRouter.
    private int _routerIndex;
    private int _builderIndex;

    private int _autoLimit => DeviceCount * SimulationEngine.AUTO_PACKET_LIMIT_PER_DEVICE;

    protected override void OnParametersSet()
    {
        // Sync the dropdown index with whatever is already selected in Config.
        _routerIndex = SimulationConfig.AvailableRouters
            .Select((r, i) => (r, i))
            .FirstOrDefault(x => x.r.Name == Config.SelectedRouter.Name).i;

        _builderIndex = SimulationConfig.AvailableNetworkBuilders
            .Select((b, i) => (b, i))
            .FirstOrDefault(x => x.b.Name == Config.SelectedNetworkBuilder.Name).i;
    }

    private void OnRouterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx)
            && idx >= 0 && idx < SimulationConfig.AvailableRouters.Count)
        {
            _routerIndex          = idx;
            Config.SelectedRouter = SimulationConfig.AvailableRouters[idx];
        }
    }

    private void OnBuilderChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx)
            && idx >= 0 && idx < SimulationConfig.AvailableNetworkBuilders.Count)
        {
            _builderIndex = idx;
            Config.SelectedNetworkBuilder = SimulationConfig.AvailableNetworkBuilders[idx];
        }
    }

    private async Task Apply()
    {
        await OnApply.InvokeAsync();
        await OnClose.InvokeAsync();
    }

    private async Task Close()           => await OnClose.InvokeAsync();
    private async Task OnBackdropClick() => await OnClose.InvokeAsync();
}
