{
  "metadata": [
    {
      "src": [
        {
          "files": ["Engine.csproj"],
          "src": "."
        }
      ],
      "dest": "api",
      "allowCompilationErrors": true,
      "properties": {
        "TargetFramework": "net9.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["toc.yml", "index.md", "**/Documentation.md"],
        "exclude": ["obj/**", "bin/**"]
      },
      {
        "files": ["api/**.yml", "api/index.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "IoT Swarm Mesh  -  Simulation Engine",
      "_appName": "IoT Swarm Mesh",
      "_appFooter": "IoT Swarm Mesh Simulation Engine * .NET 9 * Blazor WASM",
      "_enableSearch": true,
      "_noContribution": true
    },
    "template": ["default", "modern"]
  }
}
