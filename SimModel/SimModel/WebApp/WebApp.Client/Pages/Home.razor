@page "/"
@using Engine.Devices
@using WebApp.Client.Services
@using WebApp.Client.Shared
@using Engine.Benchmark
@inject SimulationService Sim
@inject BenchmarkService  BenchSvc
@implements IDisposable

<PageTitle>IoT Swarm Mesh</PageTitle>

<div class="app-shell">

    @* -- Top bar -------------------------------------------------------- *@
    <header class="topbar">
        <span class="topbar-title">IoT Swarm Mesh</span>
        <span class="topbar-stat">Tick <strong>@Sim.Engine.TickCount</strong></span>
        <span class="topbar-stat">Devices <strong>@Sim.Engine.Devices.Count</strong></span>
        <span class="topbar-stat">Packets <strong>@Sim.Engine.ActivePackets.Count / @Sim.Engine.EffectivePacketLimit</strong></span>
        <span class="topbar-stat">dt <strong>@Sim.LastTickMs.ToString("F2") ms</strong></span>

        <div class="topbar-sep"></div>

        @if (Sim.IsRunning)
        {
            <button class="btn btn-danger btn-sm" @onclick="Sim.Stop">Stop</button>
        }
        else
        {
            <button class="btn btn-primary btn-sm" @onclick="Sim.Start">Start</button>
        }
        <button class="btn btn-ghost btn-sm" @onclick="Sim.Reset"
                title="Restore layout: @Sim.ActivePresetName">Reset</button>

        <div class="topbar-sep"></div>

        @* Preset selector *@
        <select class="topbar-preset-select" @bind="_selectedPresetIndex" title="Choose a network preset">
            @for (int i = 0; i < SimulationPresets.All.Count; i++)
            {
                <option value="@i">@SimulationPresets.All[i].Name</option>
            }
        </select>
        <button class="btn btn-ghost btn-sm" @onclick="LoadSelectedPreset" title="@SelectedPresetDescription">Load</button>

        <div class="topbar-sep"></div>

        @* Random generation *@
        <input class="topbar-count" type="number" min="1" max="50" @bind="_generateCount" title="Device count for random generation" />
        <button class="btn btn-ghost btn-sm" @onclick="GenerateDevices">Random</button>

        <button class="btn btn-ghost btn-sm" @onclick="OpenSettings">Settings</button>
        <button class="btn btn-ghost btn-sm" @onclick="() => _showStats = !_showStats">Stats</button>
        <button class="btn btn-ghost btn-sm" @onclick="OpenBenchmark">Benchmark</button>
        <button class="btn btn-ghost btn-sm" @onclick="() => _showBenchLibrary = true">⊞ Library</button>
        @* Link to the DocFX documentation site deployed under /docs *@
        <a class="btn btn-docs btn-sm" href="docs/index.html" target="_blank" rel="noopener">Docs</a>

    </header>

    @* -- Packet limit error banner -------------------------------------- *@
    @if (Sim.PacketLimitError is not null)
    {
        <div class="error-banner">
            <span class="error-banner-icon">⚠</span>
            <span class="error-banner-text">@Sim.PacketLimitError</span>
            <button class="btn btn-ghost btn-sm" @onclick="Sim.Reset">Reset</button>
        </div>
    }

    @* -- Main layout ---------------------------------------------------- *@
    <main class="main-grid">

        <section class="col-left">
            <DeviceTable Devices="Sim.Engine.Devices"
                         OnAddClicked="OpenAddModal"
                         OnEditDevice="OpenEditModal"
                         OnDeleteDevice="DeleteDevice" />

            <PacketTable Packets="Sim.Engine.ActivePackets" />
        </section>

        <section class="col-right">
            <NetworkGraph Devices="Sim.Engine.Devices"
                          VisibilityDistance="Sim.Engine.VisibilityDistance" />
        </section>

    </main>

    <StatisticsPanel Stats="Sim.Statistics"
                     Visible="_showStats"
                     OnClose="() => _showStats = false"
                     OnResetStats="Sim.Statistics.Reset" />
</div>

@* -- Modals ------------------------------------------------------------- *@

@if (_showDeviceModal)
{
    <DeviceModal Model="_deviceForm"
                 IsEdit="_isEditMode"
                 OnSubmit="SubmitDeviceModal"
                 OnCancel="CloseDeviceModal" />
}

@if (_showSettings)
{
    <SimulationSettings Config="Sim.Config"
                        LastTickMs="Sim.LastTickMs"
                        DeviceCount="Sim.Engine.Devices.Count"
                        OnApply="ApplySettings"
                        OnClose="() => _showSettings = false" />
}

@* -- Benchmark config modal ----------------------------------------- *@
@if (_showBenchConfig)
{
    <BenchmarkConfigModal Config="_benchConfig"
                          SimDevices="Sim.Engine.Devices"
                          OnRun="RunBenchmark"
                          OnCancel="() => _showBenchConfig = false" />
}

@* -- Benchmark loading overlay -------------------------------------- *@
@if (BenchSvc.IsRunning)
{
    <div class="bm-loading-overlay">
        <div class="bm-loading-box">
            <div class="bm-spinner"></div>
            <p class="bm-loading-title">Running benchmark…</p>
            <p class="bm-loading-sub">@_benchProgressLabel</p>
            <div class="bm-progress-bar">
                <div class="bm-progress-fill"
                     style="width:@((BenchSvc.Progress * 100).ToString("F0"))%"></div>
            </div>
        </div>
    </div>
}

@* -- Benchmark result modal ----------------------------------------- *@
@if (_showBenchResult && BenchSvc.LastSession is not null)
{
    <BenchmarkResultModal Session="BenchSvc.LastSession"
                          OnClose="() => _showBenchResult = false"
                          OnSaved="() => {}" />
}

@if (_showBenchLibrary)
{
    <BenchmarkLibraryModal OnClose="() => _showBenchLibrary = false" />
}

@code {
    private bool _showDeviceModal;
    private bool _showSettings;
    private bool _showStats;
    private bool _isEditMode;
    private Guid _editingId;
    private DeviceFormModel _deviceForm = new();
    private int _generateCount = 6;
    private int _selectedPresetIndex = 0;

    // -- Benchmark state ------------------------------------------------
    private bool            _showBenchConfig  = false;
    private bool            _showBenchResult  = false;
    private bool            _showBenchLibrary = false;
    private BenchmarkConfig _benchConfig      = new();
    private string          _benchProgressLabel = "";
    private CancellationTokenSource _benchUiCts = new();

    private string SelectedPresetDescription =>
        SimulationPresets.All[_selectedPresetIndex].Description;

    protected override void OnInitialized()
    {
        Sim.StateChanged       += OnEngineStateChanged;
        BenchSvc.StateChanged  += OnBenchStateChanged;
    }

    private void OnEngineStateChanged() => InvokeAsync(StateHasChanged);

    private void OnBenchStateChanged()
    {
        // Update progress label while running.
        var done  = (int)Math.Round(BenchSvc.Progress * _benchConfig.RouterNames.Count);
        var total = _benchConfig.RouterNames.Count;
        _benchProgressLabel = BenchSvc.IsRunning
            ? $"Router {done} / {total}"
            : "Done";

        // When run finishes, hide config modal and show result.
        if (!BenchSvc.IsRunning && BenchSvc.LastSession is not null)
        {
            _showBenchConfig = false;
            _showBenchResult = true;
        }

        InvokeAsync(StateHasChanged);
    }

    private void LoadSelectedPreset()
    {
        Sim.LoadPreset(SimulationPresets.All[_selectedPresetIndex]);
    }

    private void OpenAddModal()
    {
        _deviceForm = new DeviceFormModel();
        _isEditMode = false;
        _showDeviceModal = true;
    }

    private void OpenEditModal(Device device)
    {
        _editingId = device.Id;
        _deviceForm = new DeviceFormModel
        {
            Name = device.Name,
            DeviceType = device switch
            {
                HubDevice       => DeviceType.Hub,
                GeneratorDevice => DeviceType.Generator,
                _               => DeviceType.Emitter
            },
            X = device.Position.X,
            Y = device.Position.Y,
            GenFrequencyTicks     = device is GeneratorDevice g ? g.GenFrequencyTicks : 40,
            ControlFrequencyTicks = device is EmitterDevice   e ? e.ControlFrequencyTicks : 0
        };
        _isEditMode = true;
        _showDeviceModal = true;
    }

    private void SubmitDeviceModal()
    {
        if (_isEditMode)
            Sim.UpdateDevice(_editingId, _deviceForm);
        else
            Sim.AddDevice(_deviceForm);

        CloseDeviceModal();
    }

    private void CloseDeviceModal() => _showDeviceModal = false;

    private void DeleteDevice(Device device) => Sim.RemoveDevice(device.Id);

    private void OpenSettings() => _showSettings = true;

    private void ApplySettings() => Sim.ApplyConfig();

    private void GenerateDevices() => Sim.GenerateRandom(_generateCount);

    private void OpenBenchmark()
    {
        // Pre-fill with a fresh config seeded from the current simulation layout.
        _benchConfig = new BenchmarkConfig
        {
            Name              = "Benchmark",
            DurationTicks     = 300,
            VisibilityDistance = Sim.Engine.VisibilityDistance,
            MaxActivePackets  = Sim.Config.MaxActivePackets,
            RouterNames       = [Sim.Config.SelectedRouter.Name],
        };
        // Import current device layout automatically.
        foreach (var d in Sim.Engine.Devices)
        {
            var dto = new DeviceBenchmarkDto { Name = d.Name, X = d.Position.X, Y = d.Position.Y };
            switch (d)
            {
                case HubDevice:
                    dto.Kind = BenchmarkDeviceKind.Hub; break;
                case GeneratorDevice g:
                    dto.Kind = BenchmarkDeviceKind.Generator;
                    dto.GenFrequencyTicks = g.GenFrequencyTicks; break;
                case EmitterDevice e:
                    dto.Kind = BenchmarkDeviceKind.Emitter;
                    dto.ControlFrequencyTicks = e.ControlFrequencyTicks; break;
            }
            _benchConfig.Devices.Add(dto);
        }
        _showBenchConfig = true;
    }

    private async Task RunBenchmark()
    {
        _showBenchConfig = false;
        // Stop the live simulation so the engine singleton is free for the runner.
        Sim.Stop();
        await BenchSvc.RunAsync(_benchConfig);
        // Restore the live simulation state after the benchmark resets the engine.
        Sim.Reset();
    }

    public void Dispose()
    {
        Sim.StateChanged      -= OnEngineStateChanged;
        BenchSvc.StateChanged -= OnBenchStateChanged;
        _benchUiCts.Dispose();
    }
}
