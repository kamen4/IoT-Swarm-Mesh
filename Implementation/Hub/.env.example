# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_USER=hub
POSTGRES_PASSWORD=hub_secret
POSTGRES_DB=hubdb

# InfluxDB
INFLUX_USER=admin
INFLUX_PASSWORD=influx_secret
INFLUX_ORG=iot-swarm
INFLUX_BUCKET=mesh-telemetry
INFLUX_TOKEN=dev-token-change-me

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secret

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# UART (serial port connected to GatewayDevice)
# /dev/ttyGATEWAY is a stable symlink created by /etc/udev/rules.d/99-iot-gateway.rules
# Fall back to /dev/ttyACM0 or /dev/ttyACM1 if the udev rule is not installed.
UART_PORT=/dev/ttyGATEWAY
UART_BAUD=115200
