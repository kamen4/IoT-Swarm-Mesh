@using Engine.Statistics
@using WebApp.Client.Shared

@implements IDisposable

<div class="stats-drawer @(_visible ? "stats-drawer--open" : "")">

    <div class="stats-drawer-header">
        <span>Statistics</span>
        <div class="stats-drawer-actions">
            <button class="btn btn-ghost btn-sm" @onclick="() => _showDetail = true">Detailed</button>
            <button class="btn btn-ghost btn-sm" @onclick="OnReset">Reset</button>
            <button class="btn btn-ghost btn-sm" @onclick="Close">X</button>
        </div>
    </div>

    <div class="stats-grid">
        @foreach (var metric in Stats.Metrics)
        {
            <div class="stat-card" title="@metric.Description">
                <span class="stat-label">@metric.Label</span>
                <span class="stat-value">@metric.DisplayValue</span>
            </div>
        }
    </div>

</div>

@if (_showDetail)
{
    <DetailedStatsModal Stats="Stats"
                        OnClose="() => _showDetail = false"
                        OnResetStats="OnReset" />
}

@code {
    [Parameter, EditorRequired] public SimulationStatistics Stats        { get; set; } = null!;
    [Parameter]                 public bool                 Visible      { get; set; }
    [Parameter]                 public EventCallback        OnClose      { get; set; }
    [Parameter]                 public EventCallback        OnResetStats { get; set; }

    private bool _visible;
    private bool _showDetail;

    // Render the metric cards at most once every 200 ms to stay smooth even
    // when hundreds of packets are delivered per tick.
    private const int RenderIntervalMs = 200;
    private CancellationTokenSource _cts = new();

    protected override void OnParametersSet() => _visible = Visible;

    protected override void OnInitialized()
    {
        // Listen for non-tick updates (e.g. device registration, reset) that
        // must be reflected immediately outside the periodic render cycle.
        Stats.Updated += OnImmediate;
        _ = RenderLoopAsync(_cts.Token);
    }

    // Called only for immediate out-of-band changes (Reset, DeviceRegistered).
    private void OnImmediate() => InvokeAsync(StateHasChanged);

    private async Task RenderLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(RenderIntervalMs));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
                await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    private async Task Close()    => await OnClose.InvokeAsync();
    private async Task OnReset()
    {
        _showDetail = false;
        await OnResetStats.InvokeAsync();
    }

    public void Dispose()
    {
        Stats.Updated -= OnImmediate;
        _cts.Cancel();
        _cts.Dispose();
    }
}
